# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For Render: use the Internal Database URL from your Render PostgreSQL service
DATABASE_URL=postgresql://postgres:password@localhost:5432/examforge

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Add your Vercel domain after deployment:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used for password reset email links
FRONTEND_URL=http://localhost:5173

# ── Email (Optional — for password reset emails) ──────────────────────────────
# Integrate SendGrid, AWS SES, or Resend
# SENDGRID_API_KEY=SG.xxxxxxxx
# EMAIL_FROM=noreply@examforge.io

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
